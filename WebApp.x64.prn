36895>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36896>>>>>    
36896>>>>>    Procedure Construct_Object
36898>>>>>        Handle hoObj
36898>>>>>        
36898>>>>>        Forward Send Construct_Object
36900>>>>>        
36900>>>>>        Set pbSessionCookieHttpOnly to True
36901>>>>>        
36901>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36902>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36903>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36904>>>>>        
36904>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36905>>>>>        Set phoUserDD to hoObj
36906>>>>>        
36906>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36907>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36908>>>>>        Set phoSessionDD to hoObj
36909>>>>>        
36909>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36910>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36911>>>>>        Set phoCrypto to hoObj
36912>>>>>        
36912>>>>>        Property Boolean pbPasswordHashing True
36913>>>>>        
36913>>>>>        Property Boolean pbCreatingNewSession False
36914>>>>>        Property String psLoginName
36915>>>>>        Property String psUserName ""
36916>>>>>        Property Integer piUserRights 0
36917>>>>>    End_Procedure
36918>>>>>    
36918>>>>>    Procedure End_Construct_Object
36920>>>>>        Forward Send End_Construct_Object
36922>>>>>        
36922>>>>>        Handle hoCrypto
36922>>>>>        Integer iFieldLen
36922>>>>>        If (pbPasswordHashing(Self)) Begin
36924>>>>>            Get phoCrypto to hoCrypto
36925>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36928>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36930>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36931>>>>>>
36931>>>>>            End
36931>>>>>>
36931>>>>>        End
36931>>>>>>
36931>>>>>    End_Procedure
36932>>>>>    
36932>>>>>    Function CreateSession String sRemoteAddress Returns String
36934>>>>>        String sSessionKey
36934>>>>>        Integer iErr
36934>>>>>        Boolean bLogWebSession
36934>>>>>        Handle hoSessionDD       
36934>>>>>        Get phoSessionDD to hoSessionDD
36935>>>>>        
36935>>>>>        //  Get session key
36935>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36937>>>>>        
36937>>>>>        Get pbLogWebSession to bLogWebSession
36938>>>>>        If not bLogWebSession Begin
36940>>>>>            Function_Return sSessionKey        
36941>>>>>        End
36941>>>>>>
36941>>>>>
36941>>>>>        //  Store session
36941>>>>>        Send Clear of hoSessionDD
36942>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36943>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36944>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36945>>>>>        Get Request_Validate of hoSessionDD to iErr
36946>>>>>        If (iErr) Begin
36948>>>>>            // this should not happen. If it does its a programming error
36948>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36949>>>>>>
36949>>>>>            Function_Return ""
36950>>>>>        End
36950>>>>>>
36950>>>>>        Send Request_Save of hoSessionDD
36951>>>>>        If (Err) Begin
36953>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36953>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36954>>>>>>
36954>>>>>            Function_Return ""
36955>>>>>        End
36955>>>>>>
36955>>>>>       
36955>>>>>        Function_Return sSessionKey        
36956>>>>>    End_Function
36957>>>>>    
36957>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36959>>>>>        DateTime dtLastAccess dtCurrent
36959>>>>>        TimeSpan tsDiff
36959>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36959>>>>>        Boolean bResult bCreatingNewSession
36959>>>>>        Boolean bLogWebSession bLoadWebApp
36959>>>>>        Integer eLoginMode
36959>>>>>        String sTime
36959>>>>>        Handle hoSessionDD hoUserDD       
36959>>>>>        
36959>>>>>        Move False to bLoadWebApp
36960>>>>>        If (num_arguments >= 2) Begin
36962>>>>>            Move bOptLoadWebApp to bLoadWebApp
36963>>>>>        End
36963>>>>>>
36963>>>>>        
36963>>>>>        Get phoSessionDD to hoSessionDD
36964>>>>>        Get phoUserDD to hoUserDD
36965>>>>>        
36965>>>>>        Get pbLogWebSession to bLogWebSession
36966>>>>>        Get peLoginMode to eLoginMode
36967>>>>>        
36967>>>>>        // for this object, you can only disable logging if login completely is disabled
36967>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36969>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36970>>>>>>
36970>>>>>            Function_Return False
36971>>>>>        End
36971>>>>>>
36971>>>>>
36971>>>>>        //  Clear session properties
36971>>>>>        Set psSessionKey to ""
36972>>>>>        Send UpdateSessionProperties True
36973>>>>>        
36973>>>>>        If not bLogWebSession Begin
36975>>>>>            Forward Get ValidateSession sSessionKey to bResult
36977>>>>>            Function_Return bResult
36978>>>>>        End        
36978>>>>>>
36978>>>>>        
36978>>>>>        Move False to bResult
36979>>>>>        Get piSessionTimeout to iSessionTimeout 
36980>>>>>        
36980>>>>>        //  Check if session exists
36980>>>>>        Send Clear of hoSessionDD
36981>>>>>        Move sSessionKey to WebAppSession.SessionKey
36982>>>>>        Send Find of hoSessionDD EQ Index.1
36983>>>>>            
36983>>>>>        If (Found) Begin
36985>>>>>            //  Calculate timespan between now and last access time
36985>>>>>            Move (CurrentDateTime()) to dtCurrent
36986>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36987>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36988>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36989>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36990>>>>>            
36990>>>>>            //  Check if session didn't time out
36990>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36992>>>>>                Forward Get ValidateSession sSessionKey to bResult
36994>>>>>                   
36994>>>>>                If (bResult) Begin
36996>>>>>                    //  Update session record
36996>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36997>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36998>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36999>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37000>>>>>                    Get Request_Validate of hoSessionDD to iErr
37001>>>>>                    If (iErr) Begin
37003>>>>>                        // this should not happen. If it does its a programming error
37003>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37004>>>>>>
37004>>>>>                        Function_Return False
37005>>>>>                    End
37005>>>>>>
37005>>>>>                    Send Request_Save of hoSessionDD
37006>>>>>                    
37006>>>>>                    //  Update user properties
37006>>>>>                    Send UpdateSessionProperties False
37007>>>>>                End
37007>>>>>>
37007>>>>>            End
37007>>>>>>
37007>>>>>            Else Begin
37008>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37008>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37009>>>>>                
37009>>>>>                If (not(bCreatingNewSession)) Begin
37011>>>>>                    If (not(bLoadWebApp)) Begin
37013>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37014>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37015>>>>>>
37015>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37016>>>>>                    End
37016>>>>>>
37016>>>>>                    Else Begin
37017>>>>>                        Set pbCreatingNewSession to True                    
37018>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37019>>>>>                        Set pbCreatingNewSession to False                        
37020>>>>>                    End
37020>>>>>>
37020>>>>>                End
37020>>>>>>
37020>>>>>            End
37020>>>>>>
37020>>>>>        End
37020>>>>>>
37020>>>>>        Else Begin
37021>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37022>>>>>>
37022>>>>>        End
37022>>>>>>
37022>>>>>        
37022>>>>>        Function_Return bResult
37023>>>>>    End_Function
37024>>>>>    
37024>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37026>>>>>        If (not(pbPasswordHashing(Self))) Begin
37028>>>>>            Move sPassword to sHash
37029>>>>>            Function_Return True
37030>>>>>        End
37030>>>>>>
37030>>>>>        
37030>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37032>>>>>            Function_Return False
37033>>>>>        End
37033>>>>>>
37033>>>>>        Move ("V1$" + sHash) to sHash
37034>>>>>        Function_Return True
37035>>>>>    End_Function
37036>>>>>    
37036>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37038>>>>>        If (not(pbPasswordHashing(Self))) Begin
37040>>>>>            Move False to bShouldUpgrade
37041>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37042>>>>>        End
37042>>>>>>
37042>>>>>        
37042>>>>>        String sVersion
37042>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37043>>>>>        If (sVersion = "V1$") Begin
37045>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37048>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37049>>>>>        End
37049>>>>>>
37049>>>>>        Else Begin
37050>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37053>>>>>            Function_Return False
37054>>>>>        End
37054>>>>>>
37054>>>>>    End_Function
37055>>>>>    
37055>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37057>>>>>        Handle hoUserDD
37057>>>>>        Integer iErr
37057>>>>>        Get phoUserDD to hoUserDD
37058>>>>>        
37058>>>>>        //  Find the user
37058>>>>>        Send Clear of hoUserDD
37059>>>>>        Move sLoginName to WebAppUser.LoginName
37060>>>>>        Send Find of hoUserDD EQ Index.1
37061>>>>>        If (Found) Begin
37063>>>>>            Send Clear of hoUserDD
37064>>>>>            Function_Return False
37065>>>>>        End
37065>>>>>>
37065>>>>>        
37065>>>>>        Send Clear of hoUserDD
37066>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37067>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37068>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37070>>>>>            Send Clear of hoUserDD
37071>>>>>            Function_Return False
37072>>>>>        End
37072>>>>>>
37072>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37073>>>>>        Get Request_Validate of hoUserDD to iErr
37074>>>>>        If (iErr) Begin
37076>>>>>            Send Clear of hoUserDD
37077>>>>>            Function_Return False
37078>>>>>        End
37078>>>>>>
37078>>>>>        
37078>>>>>        Send Request_Save of hoUserDD
37079>>>>>        Function_Return (not(Err))
37080>>>>>    End_Function
37081>>>>>    
37081>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37083>>>>>        String sSessionKey sUserPassword
37083>>>>>        Handle hoSessionDD hoUserDD
37083>>>>>        Boolean bMatch bUpgrade
37083>>>>>        
37083>>>>>        Get phoSessionDD to hoSessionDD
37084>>>>>        Get phoUserDD to hoUserDD
37085>>>>>        Integer iErr eLoginMode
37085>>>>>        
37085>>>>>        // Refind session record
37085>>>>>        Get psSessionKey to sSessionKey
37086>>>>>        Send Clear of hoSessionDD
37087>>>>>        Move sSessionKey to WebAppSession.SessionKey
37088>>>>>        Send Find of hoSessionDD EQ Index.1
37089>>>>>        
37089>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37091>>>>>            Get peLoginMode to eLoginMode
37092>>>>>            
37092>>>>>            //  Find the user
37092>>>>>            Move sLoginName to WebAppUser.LoginName
37093>>>>>            Send Find of hoUserDD EQ Index.1
37094>>>>>            
37094>>>>>            // Check username and password
37094>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37096>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37097>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37098>>>>>                
37098>>>>>                If (bMatch) Begin
37100>>>>>                    // Store the login
37100>>>>>                    If (bUpgrade) Begin
37102>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37103>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37106>>>>>                    End
37106>>>>>>
37106>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37107>>>>>                    Get Request_Validate of hoSessionDD to iErr
37108>>>>>                    If (iErr) Begin
37110>>>>>                        // this should not happen. If it does its a programming error
37110>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37111>>>>>>
37111>>>>>                        Function_Return False
37112>>>>>                    End
37112>>>>>>
37112>>>>>                    
37112>>>>>                    Send Request_Save of hoSessionDD
37113>>>>>                    
37113>>>>>                    // Update session properties
37113>>>>>                    Send UpdateSessionProperties False
37114>>>>>                    Send NotifyChangeRights
37115>>>>>                    Function_Return True
37116>>>>>                End
37116>>>>>>
37116>>>>>                Else Begin
37117>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37117>>>>>                    Send Clear of hoUserDD
37118>>>>>                End
37118>>>>>>
37118>>>>>            End
37118>>>>>>
37118>>>>>            Else Begin
37119>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37119>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37120>>>>>            End
37120>>>>>>
37120>>>>>        End
37120>>>>>>
37120>>>>>        Else Begin
37121>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37121>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37122>>>>>        End
37122>>>>>>
37122>>>>>          
37122>>>>>        Function_Return False
37123>>>>>    End_Function
37124>>>>>    
37124>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37126>>>>>        Handle hoUserDD
37126>>>>>        Integer iErr
37126>>>>>        Get phoUserDD to hoUserDD
37127>>>>>        
37127>>>>>        //  Find the user
37127>>>>>        Send Clear of hoUserDD
37128>>>>>        Move sLoginName to WebAppUser.LoginName
37129>>>>>        Send Find of hoUserDD EQ Index.1
37130>>>>>        If (not(Found)) Begin
37132>>>>>            Send Clear of hoUserDD
37133>>>>>            Function_Return False
37134>>>>>        End
37134>>>>>>
37134>>>>>        
37134>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37136>>>>>            Send Clear of hoUserDD
37137>>>>>            Function_Return False
37138>>>>>        End
37138>>>>>>
37138>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37139>>>>>        Get Request_Validate of hoUserDD to iErr
37140>>>>>        If (iErr) Begin
37142>>>>>            Send Clear of hoUserDD
37143>>>>>            Function_Return False
37144>>>>>        End
37144>>>>>>
37144>>>>>        
37144>>>>>        Send Request_Save of hoUserDD
37145>>>>>        Function_Return (not(Err))
37146>>>>>    End_Function
37147>>>>>    
37147>>>>>    Function IsLoggedIn Returns Boolean
37149>>>>>        String sLoginName
37149>>>>>        Boolean bLogWebSession bLoggedIn
37149>>>>>        
37149>>>>>        Get pbLogWebSession to bLogWebSession
37150>>>>>        If not bLogWebSession Begin
37152>>>>>            Forward Get IsLoggedIn to bLoggedIn
37154>>>>>            Function_Return bLoggedIn
37155>>>>>        End
37155>>>>>>
37155>>>>>        
37155>>>>>        Get psLoginName to sLoginName
37156>>>>>        
37156>>>>>        Function_Return (sLoginName <> "")
37157>>>>>    End_Function
37158>>>>>    
37158>>>>>    
37158>>>>>    //
37158>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37158>>>>>    // update properties based on the session and user data. Augment this function to update 
37158>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37158>>>>>    // the right records when this procedure is called.
37158>>>>>    //
37158>>>>>    // Params:
37158>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37158>>>>>    //
37158>>>>>    Procedure UpdateSessionProperties Boolean bClear
37160>>>>>        Handle hoUserDD
37160>>>>>        
37160>>>>>        Get phoUserDD to hoUserDD
37161>>>>>        
37161>>>>>        //  Update user properties
37161>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37163>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37164>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37165>>>>>            Set piUserRights to WebAppUser.Rights
37166>>>>>            
37166>>>>>            Send OnSessionPropertiesSet 
37167>>>>>        End
37167>>>>>>
37167>>>>>        Else Begin
37168>>>>>            Set psUsername to ""
37169>>>>>            Set psLoginName to ""
37170>>>>>            Set piUserRights to 0
37171>>>>>            
37171>>>>>            Send OnSessionPropertiesClear
37172>>>>>        End
37172>>>>>>
37172>>>>>    End_Procedure
37173>>>>>    
37173>>>>>    Procedure OnSessionPropertiesSet
37175>>>>>        //  Empty event stub
37175>>>>>    End_Procedure
37176>>>>>    
37176>>>>>    Procedure OnSessionPropertiesClear
37178>>>>>        //  Empty event stub
37178>>>>>    End_Procedure
37179>>>>>    
37179>>>>>    Procedure EndSession
37181>>>>>        Integer iErr
37181>>>>>        Boolean bLogWebSession
37181>>>>>        Handle hoSessionDD       
37181>>>>>        
37181>>>>>        Get phoSessionDD to hoSessionDD
37182>>>>>        Get pbLogWebSession to bLogWebSession
37183>>>>>        If not bLogWebSession Begin
37185>>>>>            Forward Send EndSession
37187>>>>>            Procedure_Return
37188>>>>>        End
37188>>>>>>
37188>>>>>            
37188>>>>>        //  Check if session exists
37188>>>>>        Send Clear of hoSessionDD
37189>>>>>        Get psSessionKey to WebAppSession.SessionKey
37190>>>>>        
37190>>>>>        Send Find of hoSessionDD EQ Index.1
37191>>>>>        If (Found) Begin
37193>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37194>>>>>            Get Request_Validate of hoSessionDD to iErr
37195>>>>>            If (iErr) Begin
37197>>>>>                // this should not happen. If it does its a programming error
37197>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37198>>>>>>
37198>>>>>                Procedure_Return
37199>>>>>            End
37199>>>>>>
37199>>>>>            Send Request_Save of hoSessionDD
37200>>>>>        End
37200>>>>>>
37200>>>>>    End_Procedure
37201>>>>>
37201>>>>>End_Class
37202>>>>>
