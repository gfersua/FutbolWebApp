36547>>>>>>>    //
36547>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36547>>>>>>>    //
36547>>>>>>>    //  Params:
36547>>>>>>>    //      dtTime  Time to convert
36547>>>>>>>    //  Returns:
36547>>>>>>>    //      String with "HH:MM:SS" format
36547>>>>>>>    //
36547>>>>>>>    Function TimeToString DateTime dtTime Returns String
36549>>>>>>>        String sHours sMinutes sSeconds
36549>>>>>>>        
36549>>>>>>>        //  Extract parts
36549>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36550>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36551>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36552>>>>>>>        
36552>>>>>>>        //  Fill out with 0
36552>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36555>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36558>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36561>>>>>>>        
36561>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36562>>>>>>>    End_Function
36563>>>>>>>    
36563>>>>>>>    //
36563>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36563>>>>>>>    //
36563>>>>>>>    //  Params:
36563>>>>>>>    //      dtTime  Datetime variable to add time to
36563>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36563>>>>>>>    //  Returns:
36563>>>>>>>    //      dtDateTime with the loaded time
36563>>>>>>>    //
36563>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36565>>>>>>>        String sHours sMinutes sSeconds
36565>>>>>>>        
36565>>>>>>>        //  Extract parts
36565>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36566>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36567>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36568>>>>>>>        
36568>>>>>>>        //  Set to DateTime
36568>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36569>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36570>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36571>>>>>>>        
36571>>>>>>>        Function_Return dtTime
36572>>>>>>>    End_Function
