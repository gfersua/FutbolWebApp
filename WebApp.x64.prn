37255>>>    Procedure DoLogin
37258>>>        String sLoginName sPassword sPrevStateHash
37258>>>        Boolean bResult
37258>>>        
37258>>>        WebGet psValue of oLoginName to sLoginName
37259>>>        WebGet psValue of oPassword to sPassword
37260>>>        
37260>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37261>>>        
37261>>>        If (bResult) Begin
37263>>>            Send Hide of oLogin
37264>>>            Send ShowHeader of ghoWebApp
37265>>>            WebSet psCSSClass of ghoWebApp to ""
37266>>>            
37266>>>            WebGet psPrevStateHash to sPrevStateHash
37267>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37268>>>            
37268>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37268>>>            WebSet psValue of oLoginName to ""
37269>>>            WebSet psValue of oPassword  to ""
37270>>>            WebSet pbVisible of oWarning to False
37271>>>        End
37271>>>>
37271>>>        Else Begin
37272>>>            WebSet pbVisible of oWarning to True
37273>>>        End
37273>>>>
37273>>>    End_Procedure
37274>>>    
37274>>>    Procedure OnSubmit
37277>>>        Send DoLogin
37278>>>    End_Procedure
