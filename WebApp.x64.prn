36702>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36703>>>>>>>                If (not(bOk)) Function_Return False
36706>>>>>>>                
36706>>>>>>>                Move True to bRequireTimeCost
36707>>>>>>>                Case Break
36708>>>>>>>            Case Else
36708>>>>>>>                Error 8710 "Invalid algorithm selected."
36709>>>>>>>>
36709>>>>>>>                Function_Return False
36710>>>>>>>        Case End
36710>>>>>>>        
36710>>>>>>>        String sSalt
36710>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36711>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36714>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36715>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36718>>>>>>>        
36718>>>>>>>        If (bRequireTimeCost) Begin
36720>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36721>>>>>>>        End
36721>>>>>>>>
36721>>>>>>>        Else Begin
36722>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36723>>>>>>>        End
36723>>>>>>>>
36723>>>>>>>        
36723>>>>>>>        Function_Return bOk
36724>>>>>>>    End_Function
36725>>>>>>>    
36725>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36727>>>>>>>        UChar[] ucaSalt
36728>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36729>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36732>>>>>>>        
36732>>>>>>>        If (num_arguments > 4) Begin
36734>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36735>>>>>>>        End
36735>>>>>>>>
36735>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36736>>>>>>>    End_Function
36737>>>>>>>    
36737>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36739>>>>>>>        Boolean bRequiresTimeCost
36739>>>>>>>        UInteger uiAlgo uiTimeCost
36739>>>>>>>        Integer iBegin iEnd
36739>>>>>>>        String sSalt
36739>>>>>>>        
36739>>>>>>>        Move 1 to iBegin
36740>>>>>>>        
36740>>>>>>>        // Parse Algo
36740>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36741>>>>>>>        If (not(iEnd)) Function_Return False
36744>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36745>>>>>>>        
36745>>>>>>>        // Parse Salt
36745>>>>>>>        Move (iEnd + 1) to iBegin
36746>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36747>>>>>>>        If (not(iEnd)) Function_Return False
36750>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36751>>>>>>>        
36751>>>>>>>        Case Begin
36751>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36753>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36756>>>>>>>                Move True to bRequiresTimeCost
36757>>>>>>>                Case Break
36758>>>>>>>            Case Else
36758>>>>>>>                Error 8710 "Invalid algorithm selected."
36759>>>>>>>>
36759>>>>>>>                Function_Return False
36760>>>>>>>        Case End
36760>>>>>>>        
36760>>>>>>>        // Parse optional timecost
36760>>>>>>>        If (bRequiresTimeCost) Begin
36762>>>>>>>            Move (iEnd + 1) to iBegin
36763>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36764>>>>>>>            If (not(iEnd)) Function_Return False
36767>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36768>>>>>>>        End
36768>>>>>>>>
36768>>>>>>>        
36768>>>>>>>        // Parse rest hash
36768>>>>>>>        Move (iEnd + 1) to iBegin
36769>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36770>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36773>>>>>>>        
36773>>>>>>>        // Base64Decode
36773>>>>>>>        UChar[] ucaSalt
36774>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36775>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36778>>>>>>>        
36778>>>>>>>        // Create new hash
36778>>>>>>>        String sNewHash
36778>>>>>>>        If (bRequiresTimeCost) Begin
36780>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36782>>>>>>>                Function_Return False 
36783>>>>>>>            End
36783>>>>>>>>
36783>>>>>>>        End
36783>>>>>>>>
36783>>>>>>>        Else Begin
36784>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36786>>>>>>>                Function_Return False 
36787>>>>>>>            End
36787>>>>>>>>
36787>>>>>>>        End
36787>>>>>>>>
36787>>>>>>>        Function_Return (sNewHash = sHash)
36788>>>>>>>    End_Function
36789>>>>>>>    
36789>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36791>>>>>>>        Boolean bRequireTimeCost
36791>>>>>>>        UBigInt ullSize
36791>>>>>>>        UChar[] ucaSalt
36792>>>>>>>        String sSalt
36792>>>>>>>        
36792>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36793>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36794>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36797>>>>>>>        
36797>>>>>>>        Case Begin
36797>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36799>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36800>>>>>>>                Move True to bRequireTimeCost
36801>>>>>>>                Case Break
36802>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36805>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36806>>>>>>>                Move True to bRequireTimeCost
36807>>>>>>>                Case Break
36808>>>>>>>            Case Else
36808>>>>>>>                Error 8710 "Invalid algorithm selected."
36809>>>>>>>>
36809>>>>>>>                Function_Return 0
36810>>>>>>>        Case End
36810>>>>>>>        
36810>>>>>>>        // calculate base64 in a non-floating-manner
36810>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36811>>>>>>>        
36811>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36812>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36813>>>>>>>        If (bRequireTimeCost) Begin
36815>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36816>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36817>>>>>>>        End
36817>>>>>>>>
36817>>>>>>>        Else Begin
36818>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36819>>>>>>>        End
36819>>>>>>>>
36819>>>>>>>        
36819>>>>>>>        Function_Return ullSize
36820>>>>>>>    End_Function
36821>>>>>>>End_Class
36822>>>>>>>
36822>>>>>>>Class cPasswordHasher is a cObject
36823>>>>>>>    
36823>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36824>>>>>>>    
36824>>>>>>>    Procedure Construct_Object
36826>>>>>>>        Forward Send Construct_Object
36828>>>>>>>        
36828>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36829>>>>>>>        Property UInteger   puiSaltSize         16
36830>>>>>>>        
36830>>>>>>>        Property UInteger   puiOptTimeCost      420000
36831>>>>>>>    End_Procedure
36832>>>>>>>    
36832>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36834>>>>>>>        Boolean bOk
36834>>>>>>>        UInteger uiAlgo
36834>>>>>>>        Get peAlgorithm to uiAlgo
36835>>>>>>>        
36835>>>>>>>        Case Begin
36835>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36837>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36840>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36841>>>>>>>                Case Break
36842>>>>>>>            Case Else
36842>>>>>>>                Error 8710 "Invalid algorithm selected."
36843>>>>>>>>
36843>>>>>>>                Function_Return False
36844>>>>>>>        Case End
36844>>>>>>>        
36844>>>>>>>        Function_Return bOk
36845>>>>>>>    End_Function
36846>>>>>>>    
36846>>>>>>>    Function RequiredBufferSize Returns UBigInt
36848>>>>>>>        UBigInt ullSize
36848>>>>>>>        UInteger uiAlgo
36848>>>>>>>        Get peAlgorithm to uiAlgo
36849>>>>>>>        
36849>>>>>>>        Case Begin
36849>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36851>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36854>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36855>>>>>>>                Case Break
36856>>>>>>>            Case Else
36856>>>>>>>                Error 8710 "Invalid algorithm selected."
36857>>>>>>>>
36857>>>>>>>                Function_Return 0
36858>>>>>>>        Case End
36858>>>>>>>        
36858>>>>>>>        Function_Return ullSize
36859>>>>>>>    End_Function
36860>>>>>>>
36860>>>>>>>End_Class
36861>>>>>
36861>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36862>>>>>    
36862>>>>>    Procedure Construct_Object
36864>>>>>        Handle hoObj
36864>>>>>        
36864>>>>>        Forward Send Construct_Object
36866>>>>>        
36866>>>>>        Set pbSessionCookieHttpOnly to True
36867>>>>>        
36867>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36868>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36869>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36870>>>>>        
36870>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36871>>>>>        Set phoUserDD to hoObj
36872>>>>>        
36872>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36873>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36874>>>>>        Set phoSessionDD to hoObj
36875>>>>>        
36875>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36876>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36877>>>>>        Set phoCrypto to hoObj
36878>>>>>        
36878>>>>>        Property Boolean pbPasswordHashing True
36879>>>>>        
36879>>>>>        Property Boolean pbCreatingNewSession False
36880>>>>>        Property String psLoginName
36881>>>>>        Property String psUserName ""
36882>>>>>        Property Integer piUserRights 0
36883>>>>>    End_Procedure
36884>>>>>    
36884>>>>>    Procedure End_Construct_Object
36886>>>>>        Forward Send End_Construct_Object
36888>>>>>        
36888>>>>>        Handle hoCrypto
36888>>>>>        Integer iFieldLen
36888>>>>>        If (pbPasswordHashing(Self)) Begin
36890>>>>>            Get phoCrypto to hoCrypto
36891>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36894>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36896>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36897>>>>>>
36897>>>>>            End
36897>>>>>>
36897>>>>>        End
36897>>>>>>
36897>>>>>    End_Procedure
36898>>>>>    
36898>>>>>    Function CreateSession String sRemoteAddress Returns String
36900>>>>>        String sSessionKey
36900>>>>>        Integer iErr
36900>>>>>        Boolean bLogWebSession
36900>>>>>        Handle hoSessionDD       
36900>>>>>        Get phoSessionDD to hoSessionDD
36901>>>>>        
36901>>>>>        //  Get session key
36901>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36903>>>>>        
36903>>>>>        Get pbLogWebSession to bLogWebSession
36904>>>>>        If not bLogWebSession Begin
36906>>>>>            Function_Return sSessionKey        
36907>>>>>        End
36907>>>>>>
36907>>>>>
36907>>>>>        //  Store session
36907>>>>>        Send Clear of hoSessionDD
36908>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36909>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36910>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36911>>>>>        Get Request_Validate of hoSessionDD to iErr
36912>>>>>        If (iErr) Begin
36914>>>>>            // this should not happen. If it does its a programming error
36914>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36915>>>>>>
36915>>>>>            Function_Return ""
36916>>>>>        End
36916>>>>>>
36916>>>>>        Send Request_Save of hoSessionDD
36917>>>>>        If (Err) Begin
36919>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36919>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36920>>>>>>
36920>>>>>            Function_Return ""
36921>>>>>        End
36921>>>>>>
36921>>>>>       
36921>>>>>        Function_Return sSessionKey        
36922>>>>>    End_Function
36923>>>>>    
36923>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36925>>>>>        DateTime dtLastAccess dtCurrent
36925>>>>>        TimeSpan tsDiff
36925>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36925>>>>>        Boolean bResult bCreatingNewSession
36925>>>>>        Boolean bLogWebSession bLoadWebApp
36925>>>>>        Integer eLoginMode
36925>>>>>        String sTime
36925>>>>>        Handle hoSessionDD hoUserDD       
36925>>>>>        
36925>>>>>        Move False to bLoadWebApp
36926>>>>>        If (num_arguments >= 2) Begin
36928>>>>>            Move bOptLoadWebApp to bLoadWebApp
36929>>>>>        End
36929>>>>>>
36929>>>>>        
36929>>>>>        Get phoSessionDD to hoSessionDD
36930>>>>>        Get phoUserDD to hoUserDD
36931>>>>>        
36931>>>>>        Get pbLogWebSession to bLogWebSession
36932>>>>>        Get peLoginMode to eLoginMode
36933>>>>>        
36933>>>>>        // for this object, you can only disable logging if login completely is disabled
36933>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36935>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36936>>>>>>
36936>>>>>            Function_Return False
36937>>>>>        End
36937>>>>>>
36937>>>>>
36937>>>>>        //  Clear session properties
36937>>>>>        Set psSessionKey to ""
36938>>>>>        Send UpdateSessionProperties True
36939>>>>>        
36939>>>>>        If not bLogWebSession Begin
36941>>>>>            Forward Get ValidateSession sSessionKey to bResult
36943>>>>>            Function_Return bResult
36944>>>>>        End        
36944>>>>>>
36944>>>>>        
36944>>>>>        Move False to bResult
36945>>>>>        Get piSessionTimeout to iSessionTimeout 
36946>>>>>        
36946>>>>>        //  Check if session exists
36946>>>>>        Send Clear of hoSessionDD
36947>>>>>        Move sSessionKey to WebAppSession.SessionKey
36948>>>>>        Send Find of hoSessionDD EQ Index.1
36949>>>>>            
36949>>>>>        If (Found) Begin
36951>>>>>            //  Calculate timespan between now and last access time
36951>>>>>            Move (CurrentDateTime()) to dtCurrent
36952>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36953>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36954>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36955>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36956>>>>>            
36956>>>>>            //  Check if session didn't time out
36956>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36958>>>>>                Forward Get ValidateSession sSessionKey to bResult
36960>>>>>                   
36960>>>>>                If (bResult) Begin
36962>>>>>                    //  Update session record
36962>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36963>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36964>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36965>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36966>>>>>                    Get Request_Validate of hoSessionDD to iErr
36967>>>>>                    If (iErr) Begin
36969>>>>>                        // this should not happen. If it does its a programming error
36969>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36970>>>>>>
36970>>>>>                        Function_Return False
36971>>>>>                    End
36971>>>>>>
36971>>>>>                    Send Request_Save of hoSessionDD
36972>>>>>                    
36972>>>>>                    //  Update user properties
36972>>>>>                    Send UpdateSessionProperties False
36973>>>>>                End
36973>>>>>>
36973>>>>>            End
36973>>>>>>
36973>>>>>            Else Begin
36974>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36974>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36975>>>>>                
36975>>>>>                If (not(bCreatingNewSession)) Begin
36977>>>>>                    If (not(bLoadWebApp)) Begin
36979>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36980>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36981>>>>>>
36981>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36982>>>>>                    End
36982>>>>>>
36982>>>>>                    Else Begin
36983>>>>>                        Set pbCreatingNewSession to True                    
36984>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36985>>>>>                        Set pbCreatingNewSession to False                        
36986>>>>>                    End
36986>>>>>>
36986>>>>>                End
36986>>>>>>
36986>>>>>            End
36986>>>>>>
36986>>>>>        End
36986>>>>>>
36986>>>>>        Else Begin
36987>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36988>>>>>>
36988>>>>>        End
36988>>>>>>
36988>>>>>        
36988>>>>>        Function_Return bResult
36989>>>>>    End_Function
36990>>>>>    
36990>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36992>>>>>        If (not(pbPasswordHashing(Self))) Begin
36994>>>>>            Move sPassword to sHash
36995>>>>>            Function_Return True
36996>>>>>        End
36996>>>>>>
36996>>>>>        
36996>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
36998>>>>>            Function_Return False
36999>>>>>        End
36999>>>>>>
36999>>>>>        Move ("V1$" + sHash) to sHash
37000>>>>>        Function_Return True
37001>>>>>    End_Function
37002>>>>>    
37002>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37004>>>>>        If (not(pbPasswordHashing(Self))) Begin
37006>>>>>            Move False to bShouldUpgrade
37007>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37008>>>>>        End
37008>>>>>>
37008>>>>>        
37008>>>>>        String sVersion
37008>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37009>>>>>        If (sVersion = "V1$") Begin
37011>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37014>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37015>>>>>        End
37015>>>>>>
37015>>>>>        Else Begin
37016>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37019>>>>>            Function_Return False
37020>>>>>        End
37020>>>>>>
37020>>>>>    End_Function
37021>>>>>    
37021>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37023>>>>>        Handle hoUserDD
37023>>>>>        Integer iErr
37023>>>>>        Get phoUserDD to hoUserDD
37024>>>>>        
37024>>>>>        //  Find the user
37024>>>>>        Send Clear of hoUserDD
37025>>>>>        Move sLoginName to WebAppUser.LoginName
37026>>>>>        Send Find of hoUserDD EQ Index.1
37027>>>>>        If (Found) Begin
37029>>>>>            Send Clear of hoUserDD
37030>>>>>            Function_Return False
37031>>>>>        End
37031>>>>>>
37031>>>>>        
37031>>>>>        Send Clear of hoUserDD
37032>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37033>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37034>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37036>>>>>            Send Clear of hoUserDD
37037>>>>>            Function_Return False
37038>>>>>        End
37038>>>>>>
37038>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37039>>>>>        Get Request_Validate of hoUserDD to iErr
37040>>>>>        If (iErr) Begin
37042>>>>>            Send Clear of hoUserDD
37043>>>>>            Function_Return False
37044>>>>>        End
37044>>>>>>
37044>>>>>        
37044>>>>>        Send Request_Save of hoUserDD
37045>>>>>        Function_Return (not(Err))
37046>>>>>    End_Function
37047>>>>>    
37047>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37049>>>>>        String sSessionKey sUserPassword
37049>>>>>        Handle hoSessionDD hoUserDD
37049>>>>>        Boolean bMatch bUpgrade
37049>>>>>        
37049>>>>>        Get phoSessionDD to hoSessionDD
37050>>>>>        Get phoUserDD to hoUserDD
37051>>>>>        Integer iErr eLoginMode
37051>>>>>        
37051>>>>>        // Refind session record
37051>>>>>        Get psSessionKey to sSessionKey
37052>>>>>        Send Clear of hoSessionDD
37053>>>>>        Move sSessionKey to WebAppSession.SessionKey
37054>>>>>        Send Find of hoSessionDD EQ Index.1
37055>>>>>        
37055>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37057>>>>>            Get peLoginMode to eLoginMode
37058>>>>>            
37058>>>>>            //  Find the user
37058>>>>>            Move sLoginName to WebAppUser.LoginName
37059>>>>>            Send Find of hoUserDD EQ Index.1
37060>>>>>            
37060>>>>>            // Check username and password
37060>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37062>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37063>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37064>>>>>                
37064>>>>>                If (bMatch) Begin
37066>>>>>                    // Store the login
37066>>>>>                    If (bUpgrade) Begin
37068>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37069>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37072>>>>>                    End
37072>>>>>>
37072>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37073>>>>>                    Get Request_Validate of hoSessionDD to iErr
37074>>>>>                    If (iErr) Begin
37076>>>>>                        // this should not happen. If it does its a programming error
37076>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37077>>>>>>
37077>>>>>                        Function_Return False
37078>>>>>                    End
37078>>>>>>
37078>>>>>                    
37078>>>>>                    Send Request_Save of hoSessionDD
37079>>>>>                    
37079>>>>>                    // Update session properties
37079>>>>>                    Send UpdateSessionProperties False
37080>>>>>                    Send NotifyChangeRights
37081>>>>>                    Function_Return True
37082>>>>>                End
37082>>>>>>
37082>>>>>                Else Begin
37083>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37083>>>>>                    Send Clear of hoUserDD
37084>>>>>                End
37084>>>>>>
37084>>>>>            End
37084>>>>>>
37084>>>>>            Else Begin
37085>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37085>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37086>>>>>            End
37086>>>>>>
37086>>>>>        End
37086>>>>>>
37086>>>>>        Else Begin
37087>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37087>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37088>>>>>        End
37088>>>>>>
37088>>>>>          
37088>>>>>        Function_Return False
37089>>>>>    End_Function
37090>>>>>    
37090>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37092>>>>>        Handle hoUserDD
37092>>>>>        Integer iErr
37092>>>>>        Get phoUserDD to hoUserDD
37093>>>>>        
37093>>>>>        //  Find the user
37093>>>>>        Send Clear of hoUserDD
37094>>>>>        Move sLoginName to WebAppUser.LoginName
37095>>>>>        Send Find of hoUserDD EQ Index.1
37096>>>>>        If (not(Found)) Begin
37098>>>>>            Send Clear of hoUserDD
37099>>>>>            Function_Return False
37100>>>>>        End
37100>>>>>>
37100>>>>>        
37100>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37102>>>>>            Send Clear of hoUserDD
37103>>>>>            Function_Return False
37104>>>>>        End
37104>>>>>>
37104>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37105>>>>>        Get Request_Validate of hoUserDD to iErr
37106>>>>>        If (iErr) Begin
37108>>>>>            Send Clear of hoUserDD
37109>>>>>            Function_Return False
37110>>>>>        End
37110>>>>>>
37110>>>>>        
37110>>>>>        Send Request_Save of hoUserDD
37111>>>>>        Function_Return (not(Err))
37112>>>>>    End_Function
37113>>>>>    
37113>>>>>    Function IsLoggedIn Returns Boolean
37115>>>>>        String sLoginName
37115>>>>>        Boolean bLogWebSession bLoggedIn
37115>>>>>        
37115>>>>>        Get pbLogWebSession to bLogWebSession
37116>>>>>        If not bLogWebSession Begin
37118>>>>>            Forward Get IsLoggedIn to bLoggedIn
37120>>>>>            Function_Return bLoggedIn
37121>>>>>        End
37121>>>>>>
37121>>>>>        
37121>>>>>        Get psLoginName to sLoginName
37122>>>>>        
37122>>>>>        Function_Return (sLoginName <> "")
37123>>>>>    End_Function
37124>>>>>    
37124>>>>>    
37124>>>>>    //
37124>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37124>>>>>    // update properties based on the session and user data. Augment this function to update 
37124>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37124>>>>>    // the right records when this procedure is called.
37124>>>>>    //
37124>>>>>    // Params:
37124>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37124>>>>>    //
37124>>>>>    Procedure UpdateSessionProperties Boolean bClear
37126>>>>>        Handle hoUserDD
37126>>>>>        
37126>>>>>        Get phoUserDD to hoUserDD
37127>>>>>        
37127>>>>>        //  Update user properties
37127>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37129>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37130>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37131>>>>>            Set piUserRights to WebAppUser.Rights
37132>>>>>            
37132>>>>>            Send OnSessionPropertiesSet 
37133>>>>>        End
37133>>>>>>
37133>>>>>        Else Begin
37134>>>>>            Set psUsername to ""
37135>>>>>            Set psLoginName to ""
37136>>>>>            Set piUserRights to 0
37137>>>>>            
37137>>>>>            Send OnSessionPropertiesClear
37138>>>>>        End
37138>>>>>>
37138>>>>>    End_Procedure
37139>>>>>    
37139>>>>>    Procedure OnSessionPropertiesSet
37141>>>>>        //  Empty event stub
37141>>>>>    End_Procedure
37142>>>>>    
37142>>>>>    Procedure OnSessionPropertiesClear
37144>>>>>        //  Empty event stub
37144>>>>>    End_Procedure
37145>>>>>    
37145>>>>>    Procedure EndSession
37147>>>>>        Integer iErr
37147>>>>>        Boolean bLogWebSession
37147>>>>>        Handle hoSessionDD       
37147>>>>>        
37147>>>>>        Get phoSessionDD to hoSessionDD
37148>>>>>        Get pbLogWebSession to bLogWebSession
37149>>>>>        If not bLogWebSession Begin
37151>>>>>            Forward Send EndSession
37153>>>>>            Procedure_Return
37154>>>>>        End
37154>>>>>>
37154>>>>>            
37154>>>>>        //  Check if session exists
37154>>>>>        Send Clear of hoSessionDD
37155>>>>>        Get psSessionKey to WebAppSession.SessionKey
37156>>>>>        
37156>>>>>        Send Find of hoSessionDD EQ Index.1
37157>>>>>        If (Found) Begin
37159>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37160>>>>>            Get Request_Validate of hoSessionDD to iErr
37161>>>>>            If (iErr) Begin
37163>>>>>                // this should not happen. If it does its a programming error
37163>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37164>>>>>>
37164>>>>>                Procedure_Return
37165>>>>>            End
37165>>>>>>
37165>>>>>            Send Request_Save of hoSessionDD
37166>>>>>        End
37166>>>>>>
37166>>>>>    End_Procedure
37167>>>>>
37167>>>>>End_Class
37168>>>>>
