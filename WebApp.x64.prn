37529>>>    Procedure SetActionButtons
37532>>>        tWebNavigateData NavigateData
37532>>>        tWebNavigateData NavigateData
37532>>>        Boolean bHasRecord
37532>>>        Handle hoDD
37532>>>
37532>>>        Get Server to hoDD
37533>>>        Get GetNavigateData to NavigateData
37534>>>        Get HasRecord of hoDD to bHasRecord
37535>>>
37535>>>        // let's hide all buttons and then Show the ones we want
37535>>>        WebSet pbRender of oEditBtn to False
37536>>>        WebSet pbRender of oSaveBtn to False
37537>>>        WebSet pbRender of oCancelChangesBtn to False
37538>>>        WebSet pbRender of oDeleteBtn to False
37539>>>
37539>>>        If (NavigateData.bReadOnly) Begin
37541>>>            WebSet pbRender of oEditBtn to True
37542>>>        End
37542>>>>
37542>>>        Else Begin
37543>>>            WebSet pbRender of oSaveBtn to True
37544>>>            WebSet pbRender of oCancelChangesBtn to True
37545>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37546>>>        End
37546>>>>
37546>>>    End_Procedure
