37279>>>    Procedure OnLoad
37282>>>        String sPrevStateHash sView
37282>>>        
37282>>>        Forward Send OnLoad
37284>>>        
37284>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37284>>>        Get StateHash of ghoWebApp to sPrevStateHash
37285>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37286>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37288>>>            WebSet psPrevStateHash to sPrevStateHash
37289>>>        End
37289>>>>
37289>>>        
37289>>>    End_Procedure
