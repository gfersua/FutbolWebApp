37911>>>        WebSet pbRender of oEditBtn to False
37912>>>        WebSet pbRender of oSaveBtn to False
37913>>>        WebSet pbRender of oCancelChangesBtn to False
37914>>>        WebSet pbRender of oDeleteBtn to False
37915>>>
37915>>>        If (NavigateData.bReadOnly) Begin
37917>>>            WebSet pbRender of oEditBtn to True
37918>>>        End
37918>>>>
37918>>>        Else Begin
37919>>>            WebSet pbRender of oSaveBtn to True
37920>>>            WebSet pbRender of oCancelChangesBtn to True
37921>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37922>>>        End
37922>>>>
37922>>>    End_Procedure
