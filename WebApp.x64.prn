36844>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36845>>>>>    
36845>>>>>    Procedure Construct_Object
36847>>>>>        Handle hoObj
36847>>>>>        
36847>>>>>        Forward Send Construct_Object
36849>>>>>        
36849>>>>>        Set pbSessionCookieHttpOnly to True
36850>>>>>        
36850>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36851>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36852>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36853>>>>>        
36853>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36854>>>>>        Set phoUserDD to hoObj
36855>>>>>        
36855>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36856>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36857>>>>>        Set phoSessionDD to hoObj
36858>>>>>        
36858>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36859>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36860>>>>>        Set phoCrypto to hoObj
36861>>>>>        
36861>>>>>        Property Boolean pbPasswordHashing True
36862>>>>>        
36862>>>>>        Property Boolean pbCreatingNewSession False
36863>>>>>        Property String psLoginName
36864>>>>>        Property String psUserName ""
36865>>>>>        Property Integer piUserRights 0
36866>>>>>    End_Procedure
36867>>>>>    
36867>>>>>    Procedure End_Construct_Object
36869>>>>>        Forward Send End_Construct_Object
36871>>>>>        
36871>>>>>        Handle hoCrypto
36871>>>>>        Integer iFieldLen
36871>>>>>        If (pbPasswordHashing(Self)) Begin
36873>>>>>            Get phoCrypto to hoCrypto
36874>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36877>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36879>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36880>>>>>>
36880>>>>>            End
36880>>>>>>
36880>>>>>        End
36880>>>>>>
36880>>>>>    End_Procedure
36881>>>>>    
36881>>>>>    Function CreateSession String sRemoteAddress Returns String
36883>>>>>        String sSessionKey
36883>>>>>        Integer iErr
36883>>>>>        Boolean bLogWebSession
36883>>>>>        Handle hoSessionDD       
36883>>>>>        Get phoSessionDD to hoSessionDD
36884>>>>>        
36884>>>>>        //  Get session key
36884>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36886>>>>>        
36886>>>>>        Get pbLogWebSession to bLogWebSession
36887>>>>>        If not bLogWebSession Begin
36889>>>>>            Function_Return sSessionKey        
36890>>>>>        End
36890>>>>>>
36890>>>>>
36890>>>>>        //  Store session
36890>>>>>        Send Clear of hoSessionDD
36891>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36892>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36893>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36894>>>>>        Get Request_Validate of hoSessionDD to iErr
36895>>>>>        If (iErr) Begin
36897>>>>>            // this should not happen. If it does its a programming error
36897>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36898>>>>>>
36898>>>>>            Function_Return ""
36899>>>>>        End
36899>>>>>>
36899>>>>>        Send Request_Save of hoSessionDD
36900>>>>>        If (Err) Begin
36902>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36902>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36903>>>>>>
36903>>>>>            Function_Return ""
36904>>>>>        End
36904>>>>>>
36904>>>>>       
36904>>>>>        Function_Return sSessionKey        
36905>>>>>    End_Function
36906>>>>>    
36906>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36908>>>>>        DateTime dtLastAccess dtCurrent
36908>>>>>        TimeSpan tsDiff
36908>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36908>>>>>        Boolean bResult bCreatingNewSession
36908>>>>>        Boolean bLogWebSession bLoadWebApp
36908>>>>>        Integer eLoginMode
36908>>>>>        String sTime
36908>>>>>        Handle hoSessionDD hoUserDD       
36908>>>>>        
36908>>>>>        Move False to bLoadWebApp
36909>>>>>        If (num_arguments >= 2) Begin
36911>>>>>            Move bOptLoadWebApp to bLoadWebApp
36912>>>>>        End
36912>>>>>>
36912>>>>>        
36912>>>>>        Get phoSessionDD to hoSessionDD
36913>>>>>        Get phoUserDD to hoUserDD
36914>>>>>        
36914>>>>>        Get pbLogWebSession to bLogWebSession
36915>>>>>        Get peLoginMode to eLoginMode
36916>>>>>        
36916>>>>>        // for this object, you can only disable logging if login completely is disabled
36916>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36918>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36919>>>>>>
36919>>>>>            Function_Return False
36920>>>>>        End
36920>>>>>>
36920>>>>>
36920>>>>>        //  Clear session properties
36920>>>>>        Set psSessionKey to ""
36921>>>>>        Send UpdateSessionProperties True
36922>>>>>        
36922>>>>>        If not bLogWebSession Begin
36924>>>>>            Forward Get ValidateSession sSessionKey to bResult
36926>>>>>            Function_Return bResult
36927>>>>>        End        
36927>>>>>>
36927>>>>>        
36927>>>>>        Move False to bResult
36928>>>>>        Get piSessionTimeout to iSessionTimeout 
36929>>>>>        
36929>>>>>        //  Check if session exists
36929>>>>>        Send Clear of hoSessionDD
36930>>>>>        Move sSessionKey to WebAppSession.SessionKey
36931>>>>>        Send Find of hoSessionDD EQ Index.1
36932>>>>>            
36932>>>>>        If (Found) Begin
36934>>>>>            //  Calculate timespan between now and last access time
36934>>>>>            Move (CurrentDateTime()) to dtCurrent
36935>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36936>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36937>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36938>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36939>>>>>            
36939>>>>>            //  Check if session didn't time out
36939>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36941>>>>>                Forward Get ValidateSession sSessionKey to bResult
36943>>>>>                   
36943>>>>>                If (bResult) Begin
36945>>>>>                    //  Update session record
36945>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36946>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36947>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36948>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36949>>>>>                    Get Request_Validate of hoSessionDD to iErr
36950>>>>>                    If (iErr) Begin
36952>>>>>                        // this should not happen. If it does its a programming error
36952>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36953>>>>>>
36953>>>>>                        Function_Return False
36954>>>>>                    End
36954>>>>>>
36954>>>>>                    Send Request_Save of hoSessionDD
36955>>>>>                    
36955>>>>>                    //  Update user properties
36955>>>>>                    Send UpdateSessionProperties False
36956>>>>>                End
36956>>>>>>
36956>>>>>            End
36956>>>>>>
36956>>>>>            Else Begin
36957>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36957>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36958>>>>>                
36958>>>>>                If (not(bCreatingNewSession)) Begin
36960>>>>>                    If (not(bLoadWebApp)) Begin
36962>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36963>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36964>>>>>>
36964>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36965>>>>>                    End
36965>>>>>>
36965>>>>>                    Else Begin
36966>>>>>                        Set pbCreatingNewSession to True                    
36967>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36968>>>>>                        Set pbCreatingNewSession to False                        
36969>>>>>                    End
36969>>>>>>
36969>>>>>                End
36969>>>>>>
36969>>>>>            End
36969>>>>>>
36969>>>>>        End
36969>>>>>>
36969>>>>>        Else Begin
36970>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36971>>>>>>
36971>>>>>        End
36971>>>>>>
36971>>>>>        
36971>>>>>        Function_Return bResult
36972>>>>>    End_Function
36973>>>>>    
36973>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36975>>>>>        If (not(pbPasswordHashing(Self))) Begin
36977>>>>>            Move sPassword to sHash
36978>>>>>            Function_Return True
36979>>>>>        End
36979>>>>>>
36979>>>>>        
36979>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
36981>>>>>            Function_Return False
36982>>>>>        End
36982>>>>>>
36982>>>>>        Move ("V1$" + sHash) to sHash
36983>>>>>        Function_Return True
36984>>>>>    End_Function
36985>>>>>    
36985>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
36987>>>>>        If (not(pbPasswordHashing(Self))) Begin
36989>>>>>            Move False to bShouldUpgrade
36990>>>>>            Function_Return (sUserPassword = sEnteredPassword)
36991>>>>>        End
36991>>>>>>
36991>>>>>        
36991>>>>>        String sVersion
36991>>>>>        Move (Left(sUserPassword, 3)) to sVersion
36992>>>>>        If (sVersion = "V1$") Begin
36994>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
36997>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
36998>>>>>        End
36998>>>>>>
36998>>>>>        Else Begin
36999>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37002>>>>>            Function_Return False
37003>>>>>        End
37003>>>>>>
37003>>>>>    End_Function
