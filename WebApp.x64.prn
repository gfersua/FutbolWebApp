37871>>>    Procedure SetActionButtons
37874>>>        tWebNavigateData NavigateData
37874>>>        tWebNavigateData NavigateData
37874>>>        Boolean bHasRecord
37874>>>        Handle hoDD
37874>>>
37874>>>        Get Server to hoDD
37875>>>        Get GetNavigateData to NavigateData
37876>>>        Get HasRecord of hoDD to bHasRecord
37877>>>
37877>>>        // let's hide all buttons and then Show the ones we want
37877>>>        WebSet pbRender of oEditBtn to False
37878>>>        WebSet pbRender of oSaveBtn to False
37879>>>        WebSet pbRender of oCancelChangesBtn to False
37880>>>        WebSet pbRender of oDeleteBtn to False
37881>>>
37881>>>        If (NavigateData.bReadOnly) Begin
37883>>>            WebSet pbRender of oEditBtn to True
37884>>>        End
37884>>>>
37884>>>        Else Begin
37885>>>            WebSet pbRender of oSaveBtn to True
37886>>>            WebSet pbRender of oCancelChangesBtn to True
37887>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37888>>>        End
37888>>>>
37888>>>    End_Procedure
37889>>>
37889>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37892>>>        // Close after save
37892>>>        Send NavigateClose Self
37893>>>    End_Procedure
37894>>>
