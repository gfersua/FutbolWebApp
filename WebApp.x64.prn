37557>>>
37557>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37560>>>        Case Begin
37560>>>            Case (NavigateData.eNavigateType = nfFromMain)
37562>>>                // If from main, this is a propbably a main file Select to Zoom.
37562>>>                Case Break
37563>>>
37563>>>            Case (NavigateData.eNavigateType = nfFromParent)
37566>>>                // If from parent, this is a constrained drill down.
37566>>>                Case Break
37567>>>
37567>>>            Case (NavigateData.eNavigateType = nfFromChild)
37570>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37570>>>                Case Break
37571>>>
37571>>>            Case Else // must be nfUndefined
37571>>>
37571>>>        Case End
37571>>>
37571>>>        Send SetActionButtons
37572>>>
