37574>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37577>>>        Case Begin
37577>>>            Case (NavigateData.eNavigateType = nfFromMain)
37579>>>                // If from main, this is a propbably a main file Select to Zoom.
37579>>>                Case Break
37580>>>
