37238>>>    Procedure DoLogin
37241>>>        String sLoginName sPassword sPrevStateHash
37241>>>        Boolean bResult
37241>>>        
37241>>>        WebGet psValue of oLoginName to sLoginName
37242>>>        WebGet psValue of oPassword to sPassword
37243>>>        
37243>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37244>>>        
37244>>>        If (bResult) Begin
37246>>>            Send Hide of oLogin
37247>>>            Send ShowHeader of ghoWebApp
37248>>>            WebSet psCSSClass of ghoWebApp to ""
37249>>>            
37249>>>            WebGet psPrevStateHash to sPrevStateHash
37250>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37251>>>            
37251>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37251>>>            WebSet psValue of oLoginName to ""
37252>>>            WebSet psValue of oPassword  to ""
37253>>>            WebSet pbVisible of oWarning to False
37254>>>        End
37254>>>>
37254>>>        Else Begin
37255>>>            WebSet pbVisible of oWarning to True
37256>>>        End
37256>>>>
37256>>>    End_Procedure
37257>>>    
37257>>>    Procedure OnSubmit
37260>>>        Send DoLogin
37261>>>    End_Procedure
37262>>>    
37262>>>    Procedure OnLoad
37265>>>        String sPrevStateHash sView
37265>>>        
37265>>>        Forward Send OnLoad
37267>>>        
37267>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37267>>>        Get StateHash of ghoWebApp to sPrevStateHash
37268>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37269>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37271>>>            WebSet psPrevStateHash to sPrevStateHash
37272>>>        End
37272>>>>
37272>>>        
37272>>>    End_Procedure
