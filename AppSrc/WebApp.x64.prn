38276>>>    Procedure SetActionButtons
38279>>>        tWebNavigateData NavigateData
38279>>>        tWebNavigateData NavigateData
38279>>>        Boolean bHasRecord
38279>>>        Handle hoDD
38279>>>
38279>>>        Get Server to hoDD
38280>>>        Get GetNavigateData to NavigateData
38281>>>        Get HasRecord of hoDD to bHasRecord
38282>>>
38282>>>        // let's hide all buttons and then Show the ones we want
38282>>>        WebSet pbRender of oEditBtn to False
38283>>>        WebSet pbRender of oSaveBtn to False
38284>>>        WebSet pbRender of oCancelChangesBtn to False
38285>>>        WebSet pbRender of oDeleteBtn to False
38286>>>
38286>>>        If (NavigateData.bReadOnly) Begin
38288>>>            WebSet pbRender of oEditBtn to True
38289>>>        End
38289>>>>
38289>>>        Else Begin
38290>>>            WebSet pbRender of oSaveBtn to True
38291>>>            WebSet pbRender of oCancelChangesBtn to True
38292>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38293>>>        End
38293>>>>
38293>>>    End_Procedure
