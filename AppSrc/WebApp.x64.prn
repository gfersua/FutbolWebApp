38307>>>        Case Begin
38307>>>            Case (NavigateData.eNavigateType = nfFromMain)
38309>>>                // If from main, this is a propbably a main file Select to Zoom.
38309>>>                Case Break
38310>>>
38310>>>            Case (NavigateData.eNavigateType = nfFromParent)
38313>>>                // If from parent, this is a constrained drill down.
38313>>>                Case Break
38314>>>
38314>>>            Case (NavigateData.eNavigateType = nfFromChild)
38317>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38317>>>                Case Break
38318>>>
38318>>>            Case Else // must be nfUndefined
38318>>>
38318>>>        Case End
38318>>>
38318>>>        Send SetActionButtons
38319>>>
38319>>>    End_Procedure
38320>>>
38320>>>End_Object 
