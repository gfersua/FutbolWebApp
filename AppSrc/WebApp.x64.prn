38871>>>        Get HasRecord of hoDD to bHasRecord
38872>>>
38872>>>        // let's hide all buttons and then Show the ones we want
38872>>>        WebSet pbRender of oEditBtn to False
38873>>>        WebSet pbRender of oSaveBtn to False
38874>>>        WebSet pbRender of oCancelChangesBtn to False
38875>>>        WebSet pbRender of oDeleteBtn to False
38876>>>
38876>>>        If (NavigateData.bReadOnly) Begin
38878>>>            WebSet pbRender of oEditBtn to True
38879>>>        End
38879>>>>
38879>>>        Else Begin
38880>>>            WebSet pbRender of oSaveBtn to True
38881>>>            WebSet pbRender of oCancelChangesBtn to True
38882>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38883>>>        End
38883>>>>
38883>>>    End_Procedure
