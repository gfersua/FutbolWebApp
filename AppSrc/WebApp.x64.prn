38886>>>        tWebNavigateData NavigateData
38886>>>        tWebNavigateData NavigateData
38886>>>        Boolean bHasRecord
38886>>>        Handle hoDD
38886>>>
38886>>>        Get Server to hoDD
38887>>>        Get GetNavigateData to NavigateData
38888>>>        Get HasRecord of hoDD to bHasRecord
38889>>>
38889>>>        // let's hide all buttons and then Show the ones we want
38889>>>        WebSet pbRender of oEditBtn to False
38890>>>        WebSet pbRender of oSaveBtn to False
38891>>>        WebSet pbRender of oCancelChangesBtn to False
38892>>>        WebSet pbRender of oDeleteBtn to False
38893>>>
38893>>>        If (NavigateData.bReadOnly) Begin
38895>>>            WebSet pbRender of oEditBtn to True
38896>>>        End
38896>>>>
38896>>>        Else Begin
38897>>>            WebSet pbRender of oSaveBtn to True
38898>>>            WebSet pbRender of oCancelChangesBtn to True
38899>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38900>>>        End
38900>>>>
38900>>>    End_Procedure
